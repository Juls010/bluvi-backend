# Bluvi backend environment variables example
# Copy to .env and set real values

# Hugging Face transcription
HUGGINGFACE_API_TOKEN=hf_REPLACE_ME
HUGGINGFACE_TRANSCRIPTION_MODEL=openai/whisper-large-v3

# Supabase (if used)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Other env vars already used by the project
DATABASE_URL=postgresql://user:pass@localhost:5432/bluvi
NODE_ENV=development
PORT=3000
NODE_ENV=production

# Comma-separated list of allowed frontend origins
# Example production: https://app.bluvi.com,https://admin.bluvi.com
ALLOWED_ORIGINS=https://app.bluvi.com

# Trust reverse proxy headers (set true behind Nginx/Render/Railway)
TRUST_PROXY=true

# Recommended values for beta launch (20-50 users)
# Global API limiter: requests per window
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=180

# Auth endpoints limiter: requests per window
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=40

# Login endpoint limiter: requests per window (stricter than general auth)
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=8

# Register endpoint limiter: requests per window (slowest)
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_REGISTER_MAX=6

# Brute-force protection for login (by email+IP combination)
LOGIN_GUARD_WINDOW_MS=900000
LOGIN_GUARD_MAX_ATTEMPTS=5
LOGIN_GUARD_BLOCK_MS=1200000

# Brute-force protection for login (global by email across all IPs)
EMAIL_GUARD_WINDOW_MS=1800000
EMAIL_GUARD_MAX_ATTEMPTS=12
EMAIL_GUARD_BLOCK_MS=2400000

DATABASE_URL=postgresql://bluvi_user:bluvi_password@localhost:5432/bluvi_database

# Activa SSL si usas Supabase u otro Postgres gestionado
DATABASE_SSL=false

# Redis local o gestionado
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
